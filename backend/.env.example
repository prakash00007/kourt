APP_ENV=development
APP_NAME=Kourt AI Copilot API
APP_VERSION=0.2.0
API_PREFIX=/api
FRONTEND_URL=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0,*.localhost
LOG_LEVEL=INFO
ENABLE_DOCS=true
ENABLE_METRICS=true
CREATE_SCHEMA_ON_STARTUP=true
DISABLE_CHROMA_TELEMETRY=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

LLM_PROVIDER=openai
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-70b-8192

RESEARCH_MODEL=claude-3-7-sonnet-20250219
SUMMARIZATION_MODEL=claude-3-7-sonnet-20250219
DRAFTING_MODEL=claude-3-7-sonnet-20250219
FALLBACK_MODEL=gpt-4.1-mini

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PATH=./data/chroma
CHROMA_COLLECTION_NAME=indian_legal_corpus
RETRIEVAL_K=6
MAX_CONTEXT_DOCUMENTS=8
MIN_SIMILARITY_SCORE=0.15
LLM_TIMEOUT_SECONDS=60

UPLOADS_DIR=./data/uploads
EXTRACTED_DIR=./data/extracted
MAX_UPLOAD_SIZE_MB=25
MAX_UPLOAD_PAGES=500
ALLOWED_UPLOAD_EXTENSIONS=.pdf
DRAFT_DAILY_LIMIT=10

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=300
MAX_PROMPT_CONTEXT_CHARS=18000
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=kourt

S3_BUCKET_NAME=kourt-documents
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION_NAME=ap-south-1
S3_USE_SSL=false
S3_VERIFY_SSL=false
S3_PRESIGN_EXPIRY_SECONDS=900
AWS_REGION=ap-south-1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kourt
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOW_ANONYMOUS_DEMO=false

KLEOPATRA_API_KEY=
KLEOPATRA_BASE_URL=https://court-api.kleopatra.io/api
